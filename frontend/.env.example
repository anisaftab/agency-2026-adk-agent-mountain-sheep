# =============================================================================
# Frontend environment variables
# =============================================================================
# Copy this file to .env.local for local dev, or set these in the Vercel
# dashboard under Project Settings → Environment Variables for production.

# Where the ADK FastAPI backend is reachable.
# Local dev (default if unset): http://127.0.0.1:8000
# Production:                   https://<your-app>.up.railway.app
AGENT_URL=https://your-backend.up.railway.app
